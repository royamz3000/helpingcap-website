DirectoryIndex index.html index.php
# BEGIN React + WordPress Hybrid
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Allow WordPress admin, login, cron, and API
  RewriteRule ^wp-admin(.*)$ - [L]
  RewriteRule ^wp-login\.php(.*)$ - [L]
  RewriteRule ^wp-cron\.php(.*)$ - [L]
  RewriteRule ^wp-json(.*)$ - [L]
  RewriteRule ^xmlrpc\.php$ - [L]

  # Allow WordPress content and includes (themes, plugins, uploads)
  RewriteRule ^wp-content(.*)$ - [L]
  RewriteRule ^wp-includes(.*)$ - [L]

  # Serve existing files and directories directly
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else goes to the React SPA
  RewriteRule ^ index.html [QSA,L]
</IfModule>
# END React + WordPress Hybrid

# Enable gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets (hashed filenames)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
</IfModule>
